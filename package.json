{
  "name": "saas-platform-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev --workspace=apps/api",
    "dev:dashboard": "npm run dev --workspace=apps/dashboard",
    "dev": "npm-run-all --parallel dev:*"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
